---
import '../styles/global.css';
import AppShell from '../components/AppShell.tsx';
import TableOfContents from '../components/TableOfContents.tsx';
import ProgressIndicator from '../components/ProgressIndicator.tsx';
import Footer from '../components/Footer.tsx';

export interface Props {
  title?: string;
  description?: string;
  layout?: string;
  currentSlug?: string;
  hideSidebar?: boolean;
  hideToc?: boolean;
  /** Skip `.prose` typography styling for pages that are custom UI, not an article (e.g. the homepage). */
  bare?: boolean;
}

const frontmatter = (Astro.props.frontmatter as Props | undefined) ?? Astro.props;
const title = frontmatter.title ?? 'Databricks Cross-Cloud Migration Runbook';
const description = frontmatter.description ?? 'Enterprise runbook for Databricks cross-cloud migration.';
const hideSidebar = frontmatter.hideSidebar;
const hideToc = frontmatter.hideToc;
const bare = frontmatter.bare;

const pathname = Astro.url.pathname.replace(/\.html$/, '').replace(/^\//, '');
const currentSlug = frontmatter.currentSlug ?? pathname;
const pageTitle = `${title} | Databricks Cross-Cloud Migration Runbook`;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-[var(--surface)] text-[var(--ink)]">
    <AppShell client:load currentSlug={currentSlug} hideSidebar={hideSidebar} />
    <ProgressIndicator client:load />
    <div class="flex pt-[var(--header-height)]">
      <div class={`flex-1 ${!hideSidebar ? 'lg:ml-[var(--sidebar-width)]' : ''}`}>
        <main class="mx-auto min-h-[calc(100vh-var(--header-height))] max-w-6xl px-6 py-10 lg:px-10">
          <div class={`flex gap-8 ${!hideToc ? '' : ''}`}>
            <article class={bare ? 'w-full max-w-none' : 'prose w-full max-w-none'}>
              <slot />
            </article>
            {!hideToc && <TableOfContents client:idle />}
          </div>
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>
