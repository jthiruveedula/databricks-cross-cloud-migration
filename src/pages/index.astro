---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.tsx';
import MigrationPlanner from '../components/MigrationPlanner.tsx';
import MigrationFlowDiagram from '../components/MigrationFlowDiagram.tsx';
import Hero from '../components/Hero.tsx';
import MetricsBand from '../components/MetricsBand.tsx';
import MigrationJourney from '../components/MigrationJourney.tsx';
import { withBase } from '../lib/paths';
import { ArrowRight, BookOpen, Cloud, Shield, Cpu, Workflow, ClipboardList, Activity, Wrench, Route } from 'lucide-react';

const sections = [
  { title: 'Overview', description: 'Migration drivers, archetypes, and decision framework.', href: '/overview/what-is-cross-cloud-migration', icon: BookOpen },
  { title: 'Discovery', description: 'Inventory workspaces, assets, dependencies, and risks.', href: '/discovery/workspace-inventory', icon: ClipboardList },
  { title: 'Cloud mappings', description: 'Azure ↔ AWS ↔ GCP construct equivalency matrix.', href: '/cloud-mappings/cross-cloud-equivalency-matrix', icon: Cloud },
  { title: 'Governance', description: 'Unity Catalog, metastore, grants, and legacy Hive.', href: '/governance/unity-catalog-strategy', icon: Shield },
  { title: 'Compute', description: 'Clusters, warehouses, policies, runtimes, and libraries.', href: '/compute/cluster-migration', icon: Cpu },
  { title: 'Pipelines', description: 'Workflows, DLT, orchestrators, and CI/CD promotion.', href: '/pipelines/workflows-jobs', icon: Workflow },
  { title: 'Execution', description: 'Waves, cutover, rollback, and hypercare.', href: '/execution/wave-planning', icon: Activity },
  { title: 'Validation', description: 'Technical, data, security, and business sign-off.', href: '/validation/technical-validation', icon: Activity },
];
---

<Layout title="Databricks Cross-Cloud Migration Runbook" description="Enterprise runbook for migrating Databricks across Azure, AWS, and GCP." hideToc bare>
  <Hero client:load />

  <MetricsBand client:load />

  <div class="my-12">
    <div class="mb-4 flex items-center gap-2">
      <Route className="h-5 w-5 text-[var(--accent)]" />
      <h2 class="text-lg font-semibold text-[var(--ink)]">End-to-end migration flow</h2>
    </div>
    <MigrationFlowDiagram client:load />
  </div>

  <MigrationJourney client:load />

  <div class="my-12">
    <MigrationPlanner client:load />
  </div>

  <div class="card-grid my-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {sections.map((s) => <Card href={withBase(s.href)} title={s.title} description={s.description} icon={s.icon} />)}
  </div>

  <div class="card-grid my-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    <Card href={withBase('/tools')} title="Migration Tools" description="Interactive planners, calculators, and builders to support migration execution." icon={Wrench} />
  </div>

  <div class="rounded-xl border border-[var(--border)] bg-[var(--surface-elevated)] p-6 md:p-8">
    <h2 class="mb-4 text-2xl font-semibold text-[var(--ink)]">What this runbook covers</h2>
    <p class="mb-6 text-[var(--ink-muted)]">
      Cross-cloud migration is not a lift-and-shift. It is a deliberate reset of identity, storage, networking, governance, and compute. This runbook gives you the decision framework, sequencing, commands, and validation patterns to execute it safely.
    </p>
    <div class="grid gap-6 md:grid-cols-3">
      <div>
        <h3 class="mb-2 font-semibold text-[var(--ink)]">Plan</h3>
        <p class="text-sm text-[var(--ink-muted)]">Inventory assets, map dependencies, assess risk, and choose the right migration archetype for your constraints.</p>
      </div>
      <div>
        <h3 class="mb-2 font-semibold text-[var(--ink)]">Migrate</h3>
        <p class="text-sm text-[var(--ink-muted)]">Move metastores, data, compute, pipelines, SQL assets, and ML artifacts with reusable automation and validation.</p>
      </div>
      <div>
        <h3 class="mb-2 font-semibold text-[var(--ink)]">Validate & cutover</h3>
        <p class="text-sm text-[var(--ink-muted)]">Reconcile data, verify IAM and networking, run business UAT, and execute blue-green cutover with rollback guardrails.</p>
      </div>
    </div>
  </div>
</Layout>
