---
import Layout from '../layouts/Layout.astro';
import nav from '../data/navigation.json';
import Card from '../components/Card.tsx';
import { ArrowLeft, FileText } from 'lucide-react';

export function getStaticPaths() {
  return nav.sections.flatMap((section) =>
    section.items.map((item) => ({
      params: { slug: item.slug },
      props: { section, item },
    }))
  );
}

const { section, item } = Astro.props;
const siblings = section.items.filter((i) => i.slug !== item.slug);
---

<Layout title={item.title} description={`${section.title} section — placeholder page.`} currentSlug={item.slug} hideToc>
  <div class="mx-auto max-w-2xl text-center py-12">
    <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-[var(--accent-soft)] text-[var(--accent)]">
      <FileText className="h-8 w-8" />
    </div>
    <h1 class="mb-4 text-3xl font-bold text-[var(--ink)]">{item.title}</h1>
    <p class="mb-8 text-[var(--ink-muted)]">
      This page is a placeholder in the <span class="font-medium text-[var(--accent)]">{section.title}</span> section. It is part of the suggested information architecture for the Databricks Cross-Cloud Migration Runbook.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a href={`/${section.items[0].slug}`} class="inline-flex items-center gap-2 rounded-lg bg-[var(--accent)] px-5 py-2.5 font-medium text-white shadow-glow">
        <ArrowLeft className="h-4 w-4" /> Go to {section.title}
      </a>
      <a href="/" class="inline-flex items-center gap-2 rounded-lg border border-[var(--border)] px-5 py-2.5 font-medium text-[var(--ink)] hover:bg-[var(--surface-hover)]">
        Return home
      </a>
    </div>
  </div>

  <div class="mt-12">
    <h2 class="mb-4 text-lg font-semibold text-[var(--ink)]">Other pages in {section.title}</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {siblings.map((s) => (
        <Card href={`/${s.slug}`} title={s.title} description={`View the ${s.title} page.`} />
      ))}
    </div>
  </div>
</Layout>
